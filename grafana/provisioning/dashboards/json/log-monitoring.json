{
  "id": null,
  "uid": "log-monitoring",
  "title": "Real-Time Log Monitoring",
  "description": "Request volume, latency/error trends, and anomaly detection (rule_based / isolation_forest / dynamic_baseline / hybrid) for the log monitoring pipeline.",
  "tags": ["log-monitoring"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Request Volume Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "SELECT window_start AS \"time\", sum(request_count) AS \"request_count\" FROM logs_agg WHERE $__timeFilter(window_start) GROUP BY window_start ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Anomaly Count Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroup(detected_at, '1m') AS \"time\", count(*) AS \"anomaly_count\" FROM anomalies WHERE $__timeFilter(detected_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Average Response Time by Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "SELECT window_start AS \"time\", endpoint, avg_latency AS \"value\" FROM logs_agg WHERE $__timeFilter(window_start) ORDER BY window_start",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "SELECT window_start AS \"time\", endpoint, error_rate AS \"value\" FROM logs_agg WHERE $__timeFilter(window_start) ORDER BY window_start",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Anomalies by Detection Method",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT detection_method, count(*) AS count FROM anomalies WHERE $__timeFilter(detected_at) GROUP BY detection_method ORDER BY detection_method",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Hybrid Severity Distribution",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT severity, count(*) AS count FROM anomalies WHERE detection_method = 'hybrid' AND $__timeFilter(detected_at) GROUP BY severity ORDER BY CASE severity WHEN 'low' THEN 1 WHEN 'medium' THEN 2 WHEN 'high' THEN 3 WHEN 'critical' THEN 4 ELSE 5 END",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Recent Anomalies",
      "type": "table",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "timestamp", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT detected_at AS \"timestamp\", endpoint, detection_method, anomaly_type, severity, anomaly_score, description FROM anomalies WHERE $__timeFilter(detected_at) ORDER BY detected_at DESC LIMIT 100",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "P95 Latency by Endpoint",
      "description": "Computed directly from logs_raw via percentile_cont(0.95) at query time - not read from logs_agg.p95_latency, which is not populated by the aggregation pipeline.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-logmonitor" },
          "rawQuery": true,
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "SELECT date_trunc('minute', timestamp) AS \"time\", endpoint, percentile_cont(0.95) WITHIN GROUP (ORDER BY response_time_ms) AS \"value\" FROM logs_raw WHERE $__timeFilter(timestamp) GROUP BY 1, endpoint ORDER BY 1",
          "refId": "A"
        }
      ]
    }
  ]
}
