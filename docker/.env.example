# Copy this file to `.env` (in this same docker/ directory) and edit as needed.
# `docker compose` automatically loads `.env` from the directory containing
# docker-compose.yml, so no extra flags are required.
#
# If you don't create a .env file at all, every value below falls back to the
# default shown here (via ${VAR:-default} in docker-compose.yml) - the stack
# works out of the box with no .env present, same as before this file existed.
#
# These are local-development-only defaults. Do not reuse them anywhere
# reachable beyond localhost.

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=logmonitor
POSTGRES_PASSWORD=logmonitor
POSTGRES_DB=logmonitor

# --- RabbitMQ -----------------------------------------------------------------
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Grafana ------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# NOTE: grafana/provisioning/datasources/postgres.yml has its own copy of the
# Postgres user/database/password (Grafana's provisioning format doesn't
# expand these particular fields from container environment variables the
# same way docker-compose.yml does). If you change POSTGRES_USER,
# POSTGRES_PASSWORD, or POSTGRES_DB above away from the defaults, update that
# file's `user:`/`database:`/`secureJsonData.password:` fields to match, or
# Grafana's dashboard will fail to connect. See CLAUDE.md for details.
